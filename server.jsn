/* =========================
   UPDATE EDIT-PRODUCT
========================= */

app.put(
"/api/edit-product/:id",
requireLogin,
async(req,res)=>{

try{

const db =
await readDB(
"products.json"
);

const products =
db.products || [];

const product =
products.find(
p =>
String(p.id) ===
String(req.params.id)
);

if(!product){

return res.json({
success:false,
message:"Produk tidak ditemukan"
});

}

if(
String(product.sellerId)
!== String(req.session.userId)
){

return res.json({
success:false,
message:"Bukan produk milik anda"
});

}

product.title =
req.body.title ||
product.title;

product.description =
req.body.description ||
product.description;

product.price =
req.body.price ||
product.price;

if(req.body.oldPrice){

product.oldPrice =
req.body.oldPrice;

}

await writeDB(
"products.json",
{
products
}
);

res.json({
success:true
});

