      const {
        productId,
        toUserId,
        message
      } = req.body;

      if (!message) {

        return res.status(400).json({
          success: false,
          message: "Pesan kosong"
        });

      }

      const db =
        await readDB(
          "chats.json"
        );

      const chats =
        db.chats || [];

      const chat = {
        id: generateId(),
        productId:
          Number(productId) || 0,
        fromUserId:
          req.session.userId,
        toUserId:
          Number(toUserId),
        message,
        read: false,
        createdAt:
          Date.now()
      };

      chats.push(chat);

      await writeDB(
        "chats.json",
        { chats }
      );

      res.json({
        success: true,
        chat
      });

    } catch {

      res.status(500).json({
        success: false
      });

    }
  }
);

