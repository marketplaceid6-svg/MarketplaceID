app.get(
  "/api/me",
  requireLogin,
  async (req, res) => {

    const db =
      await readDB(
        "users.json"
      );

const user =
  (
    db.users || []
  ).find(
    u =>
      u.id ===
      req.session.userId
  );

if (!user) {

  return res.status(404).json({
    success: false,
    message:
      "User tidak ditemukan"
  });

}

res.json({
  success: true,
  user
});
}
);

